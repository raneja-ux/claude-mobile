# ── Server ──────────────────────────────────────────────────────
PORT=8765

# ── Working directory (default: your home folder) ────────────────
# WORKING_DIR=/home/youruser/projects

# ── Permission mode ──────────────────────────────────────────────
# acceptEdits    → auto-accept file edits (safe default)
# bypassPermissions → skip ALL prompts (fully autonomous, use carefully)
PERMISSION_MODE=acceptEdits

# ── Optional auth token ──────────────────────────────────────────
# If set, the WebSocket URL must include ?token=<value>
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# AUTH_TOKEN=
